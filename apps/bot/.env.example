# Database — same Supabase connection as web app
DATABASE_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# Encryption — must match web app's ENCRYPTION_MASTER_KEY (generate with: openssl rand -hex 32)
ENCRYPTION_MASTER_KEY=

# Redis (for BullMQ job queues)
REDIS_URL=redis://localhost:6379

# Claude AI — for screenshot/PDF debt extraction
ANTHROPIC_API_KEY=

# Supabase Storage — for uploading scraped files (screenshots, PDFs)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Browser — set to "false" to show browser window for debugging (default: headless)
# BROWSER_HEADLESS=false
